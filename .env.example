# NextAuth configuratie
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Admin inlog gegevens - in productie aanpassen!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure-password-here

# Google Analytics configuratie
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Analytics API configuratie 
GA_PROPERTY_ID=your-property-id
GA_CLIENT_EMAIL=service-account-email@project-id.iam.gserviceaccount.com
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"

# Alternatieve methode: gebruik een volledig service account JSON-object 
# GA_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"key-id","private_key":"-----BEGIN PRIVATE KEY-----\\nkey-content\\n-----END PRIVATE KEY-----\\n","client_email":"service-account@project.iam.gserviceaccount.com",...rest of your service account JSON...}

# Sentry configuratie voor foutmonitoring
NEXT_PUBLIC_SENTRY_DSN=https://example@sentry.io/123456

# Supabase configuratie
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email configuratie voor Argewebhosting
SMTP_HOST=arg-plplcl14.argewebhosting.nl
SMTP_PORT=465
SMTP_USER_JEFFREY=Jeffrey@whiskyforcharity.com
SMTP_USER_INFO=info@whiskyforcharity.com
SMTP_SECURE=true 